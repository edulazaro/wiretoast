{
    "name": "edulazaro/wiretoast",
    "description": "Framework-agnostic toast notification system for Laravel, Livewire and Alpine. Pure CSS themes, custom-theme via variables, drop-in API.",
    "keywords": ["laravel", "livewire", "alpine", "toast", "notifications"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "illuminate/support": ">=11.0",
        "illuminate/view": ">=11.0"
    },
    "autoload": {
        "psr-4": {
            "EduLazaro\\Wiretoast\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EduLazaro\\Wiretoast\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Edu Lazaro",
            "email": "edu@edulazaro.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "EduLazaro\\Wiretoast\\WiretoastServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
